# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Database Configuration - Option 1: Individual credentials (for local/Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=o2c_db
DB_USER=postgres
DB_PASSWORD=tradeflow.js

# Database Configuration - Option 2: Connection URL (for Render/Supabase)
# If DATABASE_URL is set, it takes precedence over individual credentials
# DATABASE_URL=postgresql://user:password@host:5432/database

# Example Supabase URL:
# DATABASE_URL=postgresql://postgres:your-password@db.xxx.supabase.co:5432/postgres

# Example Render PostgreSQL URL:
# DATABASE_URL=postgres://user:password@dpg-xxx.oregon-postgres.render.com/database_xxx
